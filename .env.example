# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://mongo:27017/coach_ai
MONGODB_TEST_URI=mongodb://mongo_test:27017/coach_ai_test

# JWT Configuration
# IMPORTANT: Change this in production! Use a long random string (at least 32 characters)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Set Authorized redirect URIs to: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-from-cloud-console
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# GitHub OAuth Configuration
# Get these from: https://github.com/settings/developers
# 1. Create a new OAuth App
# 2. Set Authorization callback URL to: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id-from-settings
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Frontend URL (for CORS and redirects after auth)
FRONTEND_URL=http://localhost:5173
